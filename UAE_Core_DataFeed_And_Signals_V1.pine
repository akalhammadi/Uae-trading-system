//@version=5
indicator("UAE Core DataFeed + Signals V1", overlay=false)

// ===== Settings =====
secret = input.string("CHANGE_ME_SECRET", "Webhook Secret")
tfData = input.timeframe("60", "Data Timeframe")
sendCandles = input.bool(true, "Send Candle Updates")
sendSignals = input.bool(true, "Send Signals")

// Core symbols - adjust TradingView symbols if needed
s1 = input.symbol("DFM:EMAAR", "1 EMAAR")
s2 = input.symbol("ADX:ALDAR", "2 ALDAR")
s3 = input.symbol("DFM:DIB", "3 DIB")
s4 = input.symbol("ADX:FAB", "4 FAB")
s5 = input.symbol("ADX:PRESIGHT", "5 PRESIGHT")
s6 = input.symbol("ADX:BOROUGE", "6 BOROUGE")
s7 = input.symbol("ADX:ADNOCDRILL", "7 ADNOC DRILL")
s8 = input.symbol("ADX:TAQA", "8 TAQA")
s9 = input.symbol("DFM:SALIK", "9 SALIK")
s10 = input.symbol("ADX:NMDC", "10 NMDC")

f_process(sym) =>
    [o,h,l,c,v,t] = request.security(sym, tfData, [open, high, low, close, volume, time], barmerge.gaps_off, barmerge.lookahead_off)
    ma20 = request.security(sym, tfData, ta.sma(close, 20), barmerge.gaps_off, barmerge.lookahead_off)
    ma50 = request.security(sym, tfData, ta.sma(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
    vol20 = request.security(sym, tfData, ta.sma(volume, 20), barmerge.gaps_off, barmerge.lookahead_off)
    hh10 = request.security(sym, tfData, ta.highest(high, 10)[1], barmerge.gaps_off, barmerge.lookahead_off)
    ll10 = request.security(sym, tfData, ta.lowest(low, 10)[1], barmerge.gaps_off, barmerge.lookahead_off)

    trend = c > ma20 and ma20 > ma50
    volSpike = v > vol20 * 1.3
    breakout = c > hh10
    exitSig = c < ll10 or c < ma20
    entrySig = trend and volSpike and breakout

    symStr = str.tostring(sym)
    timeStr = str.tostring(t)

    candleMsg = '{"secret":"' + secret + '","type":"CANDLE_UPDATE","symbol":"' + symStr + '","exchange":"","timeframe":"' + tfData + '","time":"' + timeStr + '","open":' + str.tostring(o) + ',"high":' + str.tostring(h) + ',"low":' + str.tostring(l) + ',"close":' + str.tostring(c) + ',"volume":' + str.tostring(v) + '}'
    entryMsg = '{"secret":"' + secret + '","type":"SIGNAL","signal":"ENTRY","symbol":"' + symStr + '","exchange":"","timeframe":"' + tfData + '","time":"' + timeStr + '","price":' + str.tostring(c) + ',"volume":' + str.tostring(v) + '}'
    exitMsg = '{"secret":"' + secret + '","type":"SIGNAL","signal":"EXIT","symbol":"' + symStr + '","exchange":"","timeframe":"' + tfData + '","time":"' + timeStr + '","price":' + str.tostring(c) + ',"volume":' + str.tostring(v) + '}'

    if barstate.isconfirmed and sendCandles
        alert(candleMsg, alert.freq_once_per_bar_close)
    if barstate.isconfirmed and sendSignals and entrySig
        alert(entryMsg, alert.freq_once_per_bar_close)
    if barstate.isconfirmed and sendSignals and exitSig
        alert(exitMsg, alert.freq_once_per_bar_close)

    entrySig

e1 = f_process(s1)
e2 = f_process(s2)
e3 = f_process(s3)
e4 = f_process(s4)
e5 = f_process(s5)
e6 = f_process(s6)
e7 = f_process(s7)
e8 = f_process(s8)
e9 = f_process(s9)
e10 = f_process(s10)

plot(e1 or e2 or e3 or e4 or e5 or e6 or e7 or e8 or e9 or e10 ? 1 : 0, "Any Entry", color=color.green)
